# ── Core
NODE_ENV=production
PORT=3001
SESSION_SECRET=replace-with-long-random-string

# ── Database (auto-injected by Railway PostgreSQL plugin)
DATABASE_URL=postgresql://user:pass@host:5432/devpilot

# ── CORS
ALLOWED_ORIGINS=https://devpilot-agent.vercel.app
FRONTEND_URL=https://devpilot-agent.vercel.app

# ── Encryption (for storing user API keys)
ENCRYPTION_KEY=32-char-random-string-here-replace

# ── DevPilot License Server (optional — validate keys server-side)
LICENSE_API_URL=https://devpilot.app/api/license

# ── Cloudflare R2 (optional — BrainVault cloud sync)
STORAGE_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
STORAGE_REGION=auto
STORAGE_BUCKET=devpilot-vault
STORAGE_ACCESS_KEY=your-r2-access-key
STORAGE_SECRET_KEY=your-r2-secret-key
STORAGE_PUBLIC_URL=https://pub-xxxx.r2.dev
